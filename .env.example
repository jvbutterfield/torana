# Copy to .env and fill in — .env is gitignored.
# Bun auto-loads .env from the cwd, so `bun run src/cli.ts ...` picks
# these up with no extra flags.
#
# Used by examples/echo-bot/torana.yaml. For your own configs, add
# whatever env vars your YAML references via ${VAR}.

# Telegram bot token from @BotFather (/newbot).
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID — DM @userinfobot to get it.
MY_TELEGRAM_USER_ID=
