{
  "name": "torana",
  "version": "1.0.0-rc.1",
  "description": "Open-source Telegram gateway for agent runtimes. Configuration-driven, any-runner, webhook or polling.",
  "license": "MIT",
  "author": "Jason Butterfield <jbutterfield@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jvbutterfield/torana.git"
  },
  "bugs": {
    "url": "https://github.com/jvbutterfield/torana/issues"
  },
  "homepage": "https://github.com/jvbutterfield/torana#readme",
  "keywords": [
    "telegram",
    "bot",
    "gateway",
    "agent",
    "claude",
    "llm",
    "ai"
  ],
  "type": "module",
  "bin": {
    "torana": "dist/cli.js"
  },
  "main": "dist/main.js",
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "start": "bun run src/cli.ts start",
    "typecheck": "bun x tsc --noEmit",
    "test": "bun test",
    "lint": "bun x eslint src",
    "format": "bun x prettier --write .",
    "format:check": "bun x prettier --check .",
    "build": "bun build src/cli.ts --target=bun --outdir=dist --external bun:sqlite",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "bun-types": "^1.3.12",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  }
}
